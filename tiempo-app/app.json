{
  "expo": {
    "name": "Tiempo",
    "slug": "tiempo-app",
    "version": "4.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "tiempo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hugopvigo.tiempo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hugopvigo.tiempo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "WeatherWidget",
              "label": "Tiempo - Widget del tiempo",
              "description": "Temperatura actual y previsión del día",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tiempo necesita tu ubicación para mostrar el tiempo en tu zona."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#007AFF"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/9829422f-1608-4ad5-b622-67aecada466f"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9829422f-1608-4ad5-b622-67aecada466f"
      }
    },
    "owner": "hugopvigo",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
