{
  "expo": {
    "name": "Tiempo",
    "slug": "tiempo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "tiempo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true
    },
  "android": {
    "package": "com.hugopvigo.tiempo",
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#0D1B2A"
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": true,
    "permissions": [
      "android.permission.ACCESS_COARSE_LOCATION",
      "android.permission.ACCESS_FINE_LOCATION"
    ]
  },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tiempo necesita tu ubicación para mostrar el tiempo en tu zona."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#007AFF"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9829422f-1608-4ad5-b622-67aecada466f"
      }
    },
    "owner": "hugopvigo"
  }
}
